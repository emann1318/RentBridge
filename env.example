import React, { useState, useEffect } from 'react';
import { motion } from 'motion/react';
import axios from 'axios';
import { useLocation } from 'react-router-dom';
import { 
  Wallet, 
  ArrowUpRight, 
  ArrowDownLeft, 
  Send, 
  History, 
  Plus, 
  Minus,
  AlertTriangle,
  CheckCircle2,
  Clock,
  TrendingUp,
  Shield,
  BarChart3
} from 'lucide-react';

import Calculator from '../components/Calculator';

export default function DashboardPage({ user }) {
  const location = useLocation();
  const [wallet, setWallet] = useState(null);
  const [transactions, setTransactions] = useState([]);
  const [loans, setLoans] = useState([]);
  const [repayments, setRepayments] = useState([]);
  const [loading, setLoading] = useState(true);
  const [actionLoading, setActionLoading] = useState(false);
  const [amount, setAmount] = useState('');
  const [receiverEmail, setReceiverEmail] = useState('');
  const [activeTab, setActiveTab] = useState('ledger');

  useEffect(() => {
    const params = new URLSearchParams(location.search);
    const tab = params.get('tab');
    if (tab) {
      setActiveTab(tab);
    }
  }, [location.search]);

  const totalExposure = loans.reduce((acc, loan) => acc + (loan.status === 'approved' || loan.status === 'disbursed' ? loan.totalLoanAmount : 0), 0);
  const activeLoansCount = loans.filter(l => l.status === 'approved' || l.status === 'disbursed').length;

  const fetchData = async () => {
    try {
      const token = localStorage.getItem('rentbridge_token');
      const headers = { Authorization: `Bearer ${token}` };
      
      const [walletRes, txnsRes, loansRes, repaymentsRes] = await Promise.all([
        axios.get('/api/wallet', { headers }),
        axios.get('/api/transactions', { headers }),
        axios.get('/api/loans/applications', { headers }),
        axios.get('/api/loans/repayments', { headers })
      ]);

      setWallet(walletRes.data);
      setTransactions(txnsRes.data); 
      setLoans(loansRes.data);
      setRepayments(repaymentsRes.data);
    } catch (err) {
      console.error('Fetch Error:', err);
    } finally {
      setLoading(false);
    }
  };

  useEffect(() => {
    fetchData();
  }, []);

  const handleAction = async (type) => {
    if (!amount || amount <= 0) return;
    setActionLoading(true);
    try {
      const token = localStorage.getItem('rentbridge_token');
      const headers = { Authorization: `Bearer ${token}` };
      let res;
      
      if (type === 'deposit') {
        res = await axios.post('/api/wallet/deposit', { amount: Number(amount) }, { headers });
      } else if (type === 'withdraw') {
        res = await axios.post('/api/wallet/withdraw', { amount: Number(amount) }, { headers });
      } else if (type === 'transfer') {
        res = await axios.post('/api/wallet/transfer', { receiverEmail, amount: Number(amount) }, { headers });
      }

      alert(res.data.message);
      setAmount('');
      setReceiverEmail('');
      fetchData();
    } catch (err) {
      alert(err.response?.data?.message || 'Action failed');
    } finally {
      setActionLoading(false);
    }
  };

  const handleRepayment = async (repaymentId) => {
    setActionLoading(true);
    try {
      const token = localStorage.getItem('rentbridge_token');
      const headers = { Authorization: `Bearer ${token}` };
      const res = await axios.post(`/api/loans/repayment/${repaymentId}`, {}, { headers });
      alert(res.data.message);
      fetchData();
    } catch (err) {
      alert(err.response?.data?.message || 'Repayment failed');
    } finally {
      setActionLoading(false);
    }
  };

  if (loading) return null;

  return (
    <div className="p-8 space-y-6">
      {/* High Density Stats Row */}
      <div className="grid grid-cols-1 md:grid-cols-4 gap-4">
        <motion.div 
          initial={{ opacity: 0, y: 20 }}
          animate={{ opacity: 1, y: 0 }}
          className="card-high-density p-4"
        >
          <label className="stat-label block">Available Liquidity</label>
          <div className="flex items-end justify-between">
            <h2 className="text-2xl font-bold text-slate-900 leading-none">
              {wallet?.currency} {wallet?.balance.toLocaleString()}
            </h2>
            <span className="text-[10px] font-bold text-green-600 bg-green-50 px-1.5 py-0.5 rounded border border-green-100 flex items-center gap-1">
              <CheckCircle2 size={10} /> Active
            </span>
          </div>
          <div className="mt-4 pt-4 border-t border-slate-50 flex gap-4">
            <div>
              <p className="stat-label">Inbound</p>
              <p className="text-xs font-bold text-slate-700">+{wallet?.totalDeposits.toLocaleString()}</p>
            </div>
            <div>
              <p className="stat-label">Outbound</p>
              <p className="text-xs font-bold text-slate-700">-{wallet?.totalTransfersOut.toLocaleString()}</p>
            </div>
          </div>
        </motion.div>

        <div className="card-high-density p-4">
          <label className="stat-label block">Total Exposure</label>
          <h3 className="text-2xl font-bold text-slate-900 leading-none">PKR {totalExposure.toLocaleString()}</h3>
          <p className="text-[10px] text-slate-400 font-bold mt-2 uppercase">{activeLoansCount === 0 ? 'No active loans' : `${activeLoansCount} Active Loan${activeLoansCount > 1 ? 's' : ''}`}</p>
        </div>

        <div className="card-high-density p-4 cursor-pointer hover:bg-slate-50 transition-colors" onClick={() => setActiveTab('credit')}>
          <div className="flex justify-between items-center mb-1">
            <label className="stat-label">Credit Score</label>
            <span className="text-[8px] font-bold text-blue-500 uppercase font-mono">Verified Score</span>
          </div>
          <h3 className="text-2xl font-bold text-slate-900 leading-none">742</h3>
          <div className="w-full bg-slate-100 h-1 rounded-full mt-2 overflow-hidden">
            <div className="bg-blue-500 h-full w-[74%]"></div>
          </div>
        </div>

        <div className="card-high-density p-4 flex flex-col justify-center bg-blue-600 text-white border-blue-700">
          <label className="text-[10px] font-bold text-blue-200 uppercase tracking-widest mb-1">Account Tier</label>
          <h3 className="text-xl font-bold leading-none capitalize">{user?.role || 'Basic'}</h3>
          <p className="text-[10px] text-blue-200 font-medium mt-2">Verified Professional</p>
        </div>
      </div>

      <div className="grid grid-cols-1 lg:grid-cols-3 gap-6">
        {/* Left Column: Activity & History */}
        <div className="lg:col-span-2 space-y-6">
          <div className="flex gap-1 border-b border-slate-100 pb-px">
            {[
              { id: 'ledger', label: 'Overview', icon: History },
              { id: 'applications', label: 'My Applications', icon: Shield },
              { id: 'repayments', label: 'Repayments', icon: Clock },
              { id: 'credit', label: 'Credit Score', icon: BarChart3 }
            ].map(tab => (
              <button
                key={tab.id}
                onClick={() => setActiveTab(tab.id)}
                className={`flex items-center gap-2 px-4 py-2 text-[10px] font-bold uppercase tracking-widest transition-all border-b-2 ${
                  activeTab === tab.id 
                    ? 'border-blue-600 text-blue-600 bg-blue-50/30' 
                    : 'border-transparent text-slate-400 hover:text-slate-600 hover:bg-slate-50'
                }`}
              >
                <tab.icon size={12} />
                {tab.label}
              </button>
            ))}
          </div>

          {activeTab === 'ledger' && (
            <div className="card-high-density">
              <div className="px-6 py-4 border-b border-slate-100 flex items-center justify-between bg-slate-50/50">
                <div className="flex items-center gap-2">
                  <History size={16} className="text-slate-400" />
                  <h3 className="text-xs font-bold text-slate-900 uppercase tracking-wider">Account Overview</h3>
                </div>
                <div className="flex gap-2">
                  <button className="text-[10px] font-bold text-blue-600 bg-blue-50 px-2 py-1 rounded border border-blue-100 uppercase">Export CSV</button>
                </div>
              </div>
              
              <div className="overflow-x-auto">
                <table className="w-full text-left border-collapse">
                  <thead>
                    <tr className="bg-slate-50/50 text-[10px] font-bold text-slate-400 uppercase tracking-widest border-b border-slate-100">
                      <th className="px-6 py-3">Type</th>
                      <th className="px-6 py-3">Timestamp</th>
                      <th className="px-6 py-3 text-right">Status</th>
                      <th className="px-6 py-3 text-right">Amount</th>
                    </tr>
                  </thead>
                  <tbody className="divide-y divide-slate-100">
                    {transactions.length === 0 ? (
                      <tr>
                        <td colSpan="4" className="px-6 py-20 text-center">
                          <div className="flex flex-col items-center justify-center text-slate-400">
                            <History size={32} className="mb-2 opacity-20" />
                            <p className="text-xs font-bold uppercase tracking-widest">No activity reported</p>
                          </div>
                        </td>
                      </tr>
                    ) : (
                      transactions.map((txn, i) => (
                        <tr key={i} className="hover:bg-slate-50 transition-colors text-xs">
                          <td className="px-6 py-4">
                            <div className="flex items-center gap-3">
                              <div className={`w-8 h-8 rounded shrink-0 flex items-center justify-center ${
                                txn.type === 'deposit' ? 'bg-green-50 text-green-600' : 
                                txn.type === 'withdrawal' ? 'bg-red-50 text-red-600' : 'bg-blue-50 text-blue-600'
                              }`}>
                                {txn.type === 'deposit' ? <Plus size={14} /> : <Minus size={14} />}
                              </div>
                              <div>
                                <p className="font-bold text-slate-900 capitalize">{txn.type}</p>
                                <p className="text-[10px] text-slate-400 font-medium">#{txn.id?.slice(-8) || i}</p>
                              </div>
                            </div>
                          </td>
                          <td className="px-6 py-4 font-medium text-slate-500">
                            {new Date(txn.createdAt).toLocaleDateString()}
                          </td>
                          <td className="px-6 py-4 text-right">
                            <span className={`px-2 py-0.5 rounded-full text-[9px] font-bold uppercase tracking-widest ${
                              txn.status === 'successful' || txn.status === 'completed' ? 'bg-green-50 text-green-700 border border-green-100' : 
                              txn.status === 'flagged' ? 'bg-red-50 text-red-700 border border-red-100' : 'bg-slate-50 text-slate-500 border border-slate-100'
                            }`}>
                              {txn.status}
                            </span>
                          </td>
                          <td className={`px-6 py-4 text-right font-bold ${txn.type === 'deposit' ? 'text-green-600' : 'text-slate-900'}`}>
                            {txn.type === 'deposit' ? '+' : '-'}{txn.amount.toLocaleString()}
                          </td>
                        </tr>
                      ))
                    )}
                  </tbody>
                </table>
              </div>
            </div>
          )}

          {activeTab === 'applications' && (
            <div className="card-high-density">
               <div className="px-6 py-4 border-b border-slate-100 bg-slate-50/50">
                <h3 className="text-xs font-bold text-slate-900 uppercase tracking-wider">Active Loan Applications</h3>
              </div>
              <div className="p-6">
                {loans.length === 0 ? (
                  <div className="text-center py-12">
                    <Shield size={32} className="mx-auto mb-4 text-slate-300 opacity-50" />
                    <p className="text-xs font-bold text-slate-400 uppercase tracking-[0.1em]">No active applications</p>
                  </div>
                ) : (
                  <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
                    {loans.map(loan => (
                      <div key={loan.id} className="p-4 border border-slate-100 rounded bg-white shadow-sm hover:border-blue-200 transition-colors">
                        <div className="flex justify-between items-start mb-4">
                          <div>
                            <p className="text-[10px] font-bold text-slate-400 uppercase">Application ID</p>
                            <p className="text-xs font-bold text-slate-900">#{loan.id.slice(-6)}</p>
                          </div>
                          <span className={`px-2 py-0.5 rounded text-[9px] font-bold uppercase ${
                            loan.status === 'pending' ? 'bg-yellow-50 text-yellow-700' :
                            loan.status === 'approved' ? 'bg-green-50 text-green-700' : 'bg-slate-100 text-slate-600'
                          }`}>
                            {loan.status}
                          </span>
                        </div>
                        <div className="space-y-2">
                           <div className="flex justify-between items-center text-xs">
                             <span className="text-slate-500">Loan Amount</span>
                             <span className="font-bold">PKR {loan.totalLoanAmount.toLocaleString()}</span>
                           </div>
                           <div className="flex justify-between items-center text-xs">
                             <span className="text-slate-500">Tenure</span>
                             <span className="font-bold">{loan.tenure} Months</span>
                           </div>
                        </div>
                      </div>
                    ))}
                  </div>
                )}
              </div>
            </div>
          )}

          {activeTab === 'repayments' && (
            <div className="card-high-density">
              <div className="px-6 py-4 border-b border-slate-100 bg-slate-50/50">
                <h3 className="text-xs font-bold text-slate-900 uppercase tracking-wider">Upcoming Repayments</h3>
              </div>
              <div className="overflow-x-auto">
                <table className="w-full text-xs">
                   <thead>
                    <tr className="bg-slate-50 text-[10px] font-bold text-slate-400 uppercase tracking-widest border-b border-slate-100">
                      <th className="px-6 py-3 text-left">Due Date</th>
                      <th className="px-6 py-3 text-left">Status</th>
                      <th className="px-6 py-3 text-right">Amount</th>
                      <th className="px-6 py-3 text-right">Action</th>
                    </tr>
                  </thead>
                  <tbody className="divide-y divide-slate-100">
                    {repayments.length === 0 ? (
                      <tr>
                        <td colSpan="4" className="px-6 py-12 text-center text-slate-400">
                          <p className="text-[10px] font-bold uppercase">No repayments scheduled</p>
                        </td>
                      </tr>
                    ) : (
                      repayments.sort((a,b) => new Date(a.dueDate) - new Date(b.dueDate)).map(rep => (
                        <tr key={rep.id}>
                          <td className="px-6 py-4 font-bold text-slate-900">
                            {new Date(rep.dueDate).toLocaleDateString()}
                          </td>
                          <td className="px-6 py-4">
                            <span className={`px-2 py-0.5 rounded text-[9px] font-bold uppercase ${
                              rep.status === 'pending' ? 'bg-yellow-50 text-yellow-700' :
                              rep.status === 'paid' ? 'bg-green-50 text-green-700' : 'bg-red-50 text-red-700'
                            }`}>
                              {rep.status}
                            </span>
                          </td>
                          <td className="px-6 py-4 text-right font-bold">
                            PKR {rep.amount.toLocaleString()}
                          </td>
                          <td className="px-6 py-4 text-right">
                             {rep.status === 'pending' && (
                               <button 
                                 onClick={() => handleRepayment(rep.id)}
                                 disabled={actionLoading}
                                 className="px-3 py-1 bg-blue-600 text-white text-[9px] font-bold rounded uppercase hover:bg-blue-500 disabled:opacity-50"
                               >
                                 Pay Now
                               </button>
                             )}
                          </td>
                        </tr>
                      ))
                    )}
                  </tbody>
                </table>
              </div>
            </div>
          )}

          {activeTab === 'credit' && (
            <div className="card-high-density p-8 bg-white">
              <div className="max-w-2xl mx-auto">
                <div className="flex items-center gap-4 mb-8">
                  <div className="w-16 h-16 bg-blue-600 rounded-2xl flex items-center justify-center text-white shadow-lg shadow-blue-200">
                    <BarChart3 size={32} />
                  </div>
                  <div>
                    <h3 className="text-xl font-bold text-slate-900">Credit Health Analysis</h3>
                    <p className="text-xs text-slate-500 font-medium">NBFC Scoring Model v2.4 (Active)</p>
                  </div>
                </div>

                <div className="grid grid-cols-1 md:grid-cols-2 gap-8 mb-12">
                   <div className="space-y-6">
                      <div className="p-4 bg-slate-50 border border-slate-100 rounded-lg">
                        <div className="flex justify-between items-center mb-2">
                           <span className="text-[10px] font-bold uppercase text-slate-400">Payment Consistency</span>
                           <span className="text-[10px] font-bold text-green-600">98% Verified</span>
                        </div>
                        <div className="w-full bg-slate-200 h-1 rounded-full overflow-hidden">
                           <div className="bg-green-500 h-full w-[98%]"></div>
                        </div>
                      </div>
                      <div className="p-4 bg-slate-50 border border-slate-100 rounded-lg">
                        <div className="flex justify-between items-center mb-2">
                           <span className="text-[10px] font-bold uppercase text-slate-400">Debt to Income Ratio</span>
                           <span className="text-[10px] font-bold text-blue-600">Low (Optimal)</span>
                        </div>
                        <div className="w-full bg-slate-200 h-1 rounded-full overflow-hidden">
                           <div className="bg-blue-500 h-full w-[24%]"></div>
                        </div>
                      </div>
                   </div>
                   <div className="flex flex-col items-center justify-center border-l border-slate-100 pl-8">
                      <p className="text-[10px] font-bold text-slate-400 uppercase tracking-widest mb-2">Current Score</p>
                      <h4 className="text-5xl font-black text-slate-900">742</h4>
                      <p className="text-xs font-bold text-green-600 mt-2 uppercase tracking-tight">Excellent Standing</p>
                   </div>
                </div>

                <div className="p-4 bg-blue-50/50 rounded-lg border border-blue-100">
                   <div className="flex gap-3">
                      <Shield className="text-blue-600 shrink-0" size={20} />
                      <div>
                        <h5 className="text-xs font-bold text-blue-900 uppercase">NBFC Protection Active</h5>
                        <p className="text-[10px] text-blue-700 mt-1 leading-relaxed">
                          Your profile is currently protected by our NBFC Compliance Shield. Timely repayments are automatically reporting to major credit bureaus.
                        </p>
                      </div>
                   </div>
                </div>
              </div>
            </div>
          )}

          {activeTab === 'apply' && (
            <div className="card-high-density p-8 bg-white">
              <div className="max-w-md mx-auto">
                <div className="text-center mb-8">
                  <div className="w-12 h-12 bg-blue-50 rounded-lg flex items-center justify-center text-blue-600 mx-auto mb-4">
                    <Shield size={24} />
                  </div>
                  <h3 className="text-lg font-bold text-slate-900">NBFC Loan Application</h3>
                  <p className="text-xs text-slate-500 mt-1">Submit your request for rent deposit financing.</p>
                </div>
                
                <form onSubmit={async (e) => {
                  e.preventDefault();
                  const formData = new FormData(e.target);
                  const data = {
                    rentAmount: Number(formData.get('rentAmount')),
                    advanceMonths: Number(formData.get('advanceMonths')),
                    securityMonths: Number(formData.get('securityMonths')),
                    tenure: Number(formData.get('tenure'))
                  };
                  
                  setActionLoading(true);
                  try {
                    const token = localStorage.getItem('rentbridge_token');
                    const headers = { Authorization: `Bearer ${token}` };
                    await axios.post('/api/loans/apply', data, { headers });
                    alert('Application submitted successfully!');
                    setActiveTab('applications');
                    fetchData();
                  } catch (err) {
                    alert(err.response?.data?.message || 'Application failed');
                  } finally {
                    setActionLoading(false);
                  }
                }} className="space-y-4">
                  <div>
                    <label className="stat-label">Monthly Rent (PKR)</label>
                    <input name="rentAmount" type="number" required className="w-full px-4 py-2 bg-slate-50 border border-slate-200 rounded text-sm font-bold focus:outline-none focus:ring-1 focus:ring-blue-500" placeholder="50000" />
                  </div>
                  <div className="grid grid-cols-2 gap-4">
                    <div>
                      <label className="stat-label">Advance Months</label>
                      <select name="advanceMonths" className="w-full px-4 py-2 bg-slate-50 border border-slate-200 rounded text-sm font-bold focus:outline-none">
                        {[1, 2, 3, 4, 6].map(m => <option key={m} value={m}>{m} Months</option>)}
                      </select>
                    </div>
                    <div>
                      <label className="stat-label">Security Deposit</label>
                      <select name="securityMonths" className="w-full px-4 py-2 bg-slate-50 border border-slate-200 rounded text-sm font-bold focus:outline-none">
                        {[1, 2, 3].map(m => <option key={m} value={m}>{m} Months</option>)}
                      </select>
                    </div>
                  </div>
                  <div>
                    <label className="stat-label">Lease Tenure</label>
                    <select name="tenure" className="w-full px-4 py-2 bg-slate-50 border border-slate-200 rounded text-sm font-bold focus:outline-none">
                      {[6, 11, 12, 24].map(m => <option key={m} value={m}>{m} Months</option>)}
                    </select>
                  </div>
                  <button 
                    type="submit"
                    disabled={actionLoading}
                    className="w-full py-3 bg-slate-900 text-white rounded font-bold text-xs uppercase tracking-widest shadow-sm hover:bg-slate-800 disabled:opacity-50 mt-6"
                  >
                    {actionLoading ? 'Processing...' : 'Submit Application'}
                  </button>
                </form>
              </div>
            </div>
          )}

          <div className="grid grid-cols-1 md:grid-cols-2 gap-6">
             <Calculator />
             <div className="card-high-density p-8 text-center flex flex-col items-center justify-center bg-slate-900 text-white relative overflow-hidden">
                <div className="relative z-10">
                  <div className="w-16 h-16 bg-blue-500/20 rounded-full flex items-center justify-center mb-6 text-blue-400 mx-auto">
                    <TrendingUp size={32} />
                  </div>
                  <h4 className="text-xl font-bold mb-3 tracking-tight">Smart Liquidity Insights</h4>
                  <p className="text-slate-400 text-xs leading-relaxed max-w-xs mx-auto">
                    Our platform is analyzing Karachi's rental market trends and your salary patterns. 
                  </p>
                  <button 
                    onClick={() => setActiveTab('apply')}
                    className="mt-8 px-6 py-2 bg-blue-600 text-white text-[10px] font-bold rounded uppercase tracking-widest hover:bg-blue-500 transition-colors"
                  >
                    Apply for Loan
                  </button>
                </div>
                <div className="absolute top-0 right-0 p-4 opacity-10">
                   <Shield size={60} />
                </div>
             </div>
          </div>
        </div>

        {/* Right Column: Mini Wallet Controls */}
        <div className="space-y-6">
          <div className="card-high-density p-6">
            <h3 className="text-xs font-bold text-slate-900 uppercase tracking-widest mb-6">Execution Panel</h3>
            <div className="space-y-4">
              <div>
                <label className="stat-label">Reference Amount</label>
                <div className="relative">
                  <span className="absolute left-3 top-1/2 -translate-y-1/2 text-slate-400 text-xs font-bold">PKR</span>
                  <input 
                    type="number" 
                    value={amount}
                    onChange={(e) => setAmount(e.target.value)}
                    placeholder="0.00"
                    className="w-full pl-12 pr-4 py-2 bg-slate-50 border border-slate-200 rounded font-bold text-sm focus:outline-none focus:ring-1 focus:ring-blue-500 transition-all"
                  />
                </div>
              </div>
              
              <div className="grid grid-cols-2 gap-2">
                <button 
                  onClick={() => handleAction('deposit')}
                  disabled={actionLoading}
                  className="flex items-center justify-center gap-2 py-2 bg-slate-900 text-white rounded text-[10px] font-bold uppercase tracking-widest hover:bg-slate-800 transition-all disabled:opacity-50"
                >
                  <Plus size={14} /> Deposit
                </button>
                <button 
                  onClick={() => handleAction('withdraw')}
                  disabled={actionLoading}
                  className="flex items-center justify-center gap-2 py-2 bg-white border border-slate-200 text-slate-900 rounded text-[10px] font-bold uppercase tracking-widest hover:bg-slate-50 transition-all disabled:opacity-50"
                >
                  <Minus size={14} /> Withdraw
                </button>
              </div>

              <div className="pt-6 mt-6 border-t border-slate-100 space-y-4">
                <div>
                  <label className="stat-label">Receiver Identifier</label>
                  <input 
                    type="email" 
                    value={receiverEmail}
                    onChange={(e) => setReceiverEmail(e.target.value)}
                    placeholder="Email or System ID"
                    className="w-full px-4 py-2 bg-slate-50 border border-slate-200 rounded text-xs font-medium focus:outline-none focus:ring-1 focus:ring-blue-500 transition-all"
                  />
                </div>
                <button 
                  onClick={() => handleAction('transfer')}
                  disabled={actionLoading}
                  className="w-full flex items-center justify-center gap-2 py-3 bg-blue-600 text-white rounded font-bold text-xs uppercase tracking-widest shadow-sm hover:bg-blue-500 transition-all disabled:opacity-50"
                >
                  <Send size={14} /> Execute Transfer
                </button>
              </div>
            </div>
          </div>

          <div className="card-high-density p-4 bg-yellow-50/50 border-yellow-100">
             <div className="flex gap-3">
                <AlertTriangle className="text-yellow-600 shrink-0" size={16} />
                <div>
                   <h5 className="text-[10px] font-bold text-yellow-800 uppercase tracking-wider mb-1">Compliance Notice</h5>
                   <p className="text-[10px] text-yellow-700 leading-normal">
                      Deposits exceeding 50,000 PKR require manual verification of employment status.
                   </p>
                </div>
             </div>
          </div>
        </div>
      </div>
    </div>
  );
}
